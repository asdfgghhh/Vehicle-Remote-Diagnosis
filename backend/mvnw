# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script, version 3.3.4
#
# Optional ENV vars
# -----------------
#   JAVA_HOME - location of a JDK home dir, required when download maven via java source
#   MVNW_REPOURL - repo url base for downloading maven distribution
#   MVNW_USERNAME/MVNW_PASSWORD - user and password for downloading maven
#   MVNW_VERBOSE - true: enable verbose log; debug: trace the mvnw script; others: silence the output
# ----------------------------------------------------------------------------

set -euf
[ "${MVNW_VERBOSE-}" != debug ] || set -x

# OS specific support.
native_path() { printf %s\\n "$1"; }
case "$(uname)" in
CYGWIN* | MINGW*)
  [ -z "${JAVA_HOME-}" ] || JAVA_HOME="$(cygpath --unix "$JAVA_HOME")"
  native_path() { cygpath --path --windows "$1"; }
  ;;
esac

# set JAVACMD and JAVA_HOME
set_java_home() {
  if [ -n "${JAVA_HOME-}" ]; then
    if [ -x "$JAVA_HOME/jre/sh/java" ]; then
      JAVACMD="$JAVA_HOME/jre/sh/java"
    else
      JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ]; then
      die "JAVA_HOME is set to an invalid directory: $JAVA_HOME"
    fi
  else
    JAVACMD="$(which java 2>/dev/null)" || die "JAVA_HOME is not set and no 'java' command could be found in your PATH."
  fi
}

# Download maven if needed
download_maven() {
  if [ ! -d "$MAVEN_HOME" ]; then
    MAVEN_VERSION="3.9.6"
    MVNW_REPOURL="${MVNW_REPOURL:-https://repo.maven.apache.org/maven2}"
    MAVEN_DOWNLOAD_URL="$MVNW_REPOURL/org/apache/maven/apache-maven/$MAVEN_VERSION/apache-maven-$MAVEN_VERSION-bin.tar.gz"
    
    echo "Downloading Maven $MAVEN_VERSION..."
    mkdir -p "$MAVEN_HOME"
    curl -sSL "$MAVEN_DOWNLOAD_URL" | tar -xz -C "$MAVEN_HOME" --strip-components=1
  fi
}

# Main execution
set_java_home
MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.6-bin/1j2p5q99c93md6o6q0k534175m"
download_maven

exec "$MAVEN_HOME/bin/mvn" "$@"